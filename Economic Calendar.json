    {
      "parameters": {
        "jsCode": "const allEvents = Array.isArray($json)\n  ? $json\n  : (Array.isArray($input.all().map(i => i.json).flat())\n      ? $input.all().map(i => i.json).flat()\n      : []);\n\n// Filter: USD only, High + Medium impact\nconst filtered = allEvents.filter(e => {\n  if (!e || !e.title) return false;\n  if (e.country !== 'USD') return false;\n  const impact = (e.impact || '').toLowerCase();\n  return impact === 'high' || impact === 'medium';\n}).sort((a, b) => (a.date || '').localeCompare(b.date || ''));\n\nconst now = new Date();\nconst year = now.getUTCFullYear();\nconst dstStart = new Date(Date.UTC(year, 2, 8 + (7 - new Date(Date.UTC(year, 2, 8)).getUTCDay()) % 7, 7));\nconst dstEnd   = new Date(Date.UTC(year, 10, 1 + (7 - new Date(Date.UTC(year, 10, 1)).getUTCDay()) % 7, 6));\nconst etOffsetHours = (now >= dstStart && now < dstEnd) ? -4 : -5;\nconst etNow = new Date(now.getTime() + (etOffsetHours * 60 * 60 * 1000));\nconst tzLabel = etOffsetHours === -4 ? 'EDT' : 'EST';\n\nconst pad = n => String(n).padStart(2, '0');\nconst fmt = d => d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', timeZone: 'UTC' });\nconst day = etNow.getUTCDay();\nconst diffToMon = (day === 0) ? 0 : (1 - day);\nconst monday = new Date(etNow); monday.setUTCDate(etNow.getUTCDate() + diffToMon);\nconst sunday = new Date(monday); sunday.setUTCDate(monday.getUTCDate() + 6);\nconst weekLabel = fmt(monday) + ' \\u2013 ' + fmt(sunday) + ', ' + etNow.getUTCFullYear();\nconst dateStr = etNow.getUTCFullYear() + '-' + pad(etNow.getUTCMonth()+1) + '-' + pad(etNow.getUTCDate());\n\nconst fmtTime = rawDate => {\n  try {\n    const t = (rawDate || '').split('T')[1];\n    if (!t) return 'All Day';\n    const parts = t.replace(/[+-]\\d{4}$/, '').split(':');\n    let h = parseInt(parts[0]);\n    const m = parts[1];\n    const ampm = h >= 12 ? 'PM' : 'AM';\n    if (h > 12) h -= 12;\n    if (h === 0) h = 12;\n    return h + ':' + m + ' ' + ampm + ' ' + tzLabel;\n  } catch(e) { return 'TBD'; }\n};\n\nif (!filtered.length) {\n  const msg = [\n    '**\\uD83D\\uDCCA ECONOMIC CALENDAR \\u2014 WEEK AHEAD**',\n    '**\\uD83D\\uDCC5 Week of ' + weekLabel + '**',\n    '\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501',\n    '',\n    '_No major USD events this week._',\n    '_Source: Forex Factory_'\n  ].join('\\n');\n  return [{ json: { message: msg, mode: 'weekly', date: dateStr, eventCount: 0, eventsForSheets: [] } }];\n}\n\n// Group by calendar date\nconst byDay = {};\nfiltered.forEach(e => {\n  const d = (e.date || '').substring(0, 10);\n  if (!byDay[d]) byDay[d] = [];\n  byDay[d].push(e);\n});\n\nconst impactEmoji = { high: '\\uD83D\\uDD34', medium: '\\uD83D\\uDFE1' };\nconst dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];\n\nconst lines = [\n  '**\\uD83D\\uDCCA ECONOMIC CALENDAR \\u2014 WEEK AHEAD**',\n  '**\\uD83D\\uDCC5 Week of ' + weekLabel + '**',\n  '\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501',\n  ''\n];\n\nObject.keys(byDay).sort().forEach(dateKey => {\n  const d = new Date(dateKey + 'T12:00:00Z');\n  const label = dayNames[d.getUTCDay()] + '  ' + (d.getUTCMonth()+1) + '/' + d.getUTCDate();\n  lines.push('**\\uD83D\\uDCCC ' + label + '**');\n  lines.push('\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500');\n  byDay[dateKey].forEach(e => {\n    const emoji = impactEmoji[(e.impact||'').toLowerCase()] || '\\u26AA';\n    const time  = fmtTime(e.date);\n    const fore  = e.forecast ? '  Fcst: `' + e.forecast + '`' : '';\n    const prev  = e.previous ? '  \\u2502  Prev: `' + e.previous + '`' : '';\n    const meta  = (fore || prev) ? '\\n> ' + (fore + prev).trim() : '';\n    lines.push(emoji + ' **' + e.title + '**  \\u00B7  ' + time + meta);\n  });\n  lines.push('');\n});\n\nlines.push('\\uD83D\\uDD34 High Impact  \\u2502  \\uD83D\\uDFE1 Medium Impact');\nlines.push('_Source: Forex Factory \\u2502 Times in ' + tzLabel + '_');\n\nconst eventsForSheets = filtered.map(e => ({\n  date: (e.date || '').substring(0, 10),\n  event: e.title || '',\n  time_et: fmtTime(e.date),\n  impact: e.impact || '',\n  currency: e.country || 'USD',\n  forecast: e.forecast || '',\n  previous: e.previous || '',\n  actual: '',\n  mode: 'weekly_preview'\n}));\n\nreturn [{ json: { message: lines.join('\\n'), mode: 'weekly', date: dateStr, eventCount: filtered.length, eventsForSheets } }];"
      },
