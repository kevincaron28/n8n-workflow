    {
      "parameters": {
        "jsCode": "const allEvents = Array.isArray($json)\n  ? $json\n  : (Array.isArray($input.all().map(i => i.json).flat())\n      ? $input.all().map(i => i.json).flat()\n      : []);\n\n// DST-aware ET offset\nconst now = new Date();\nconst year = now.getUTCFullYear();\nconst dstStart = new Date(Date.UTC(year, 2, 8 + (7 - new Date(Date.UTC(year, 2, 8)).getUTCDay()) % 7, 7));\nconst dstEnd   = new Date(Date.UTC(year, 10, 1 + (7 - new Date(Date.UTC(year, 10, 1)).getUTCDay()) % 7, 6));\nconst etOffsetHours = (now >= dstStart && now < dstEnd) ? -4 : -5;\nconst etNow = new Date(now.getTime() + (etOffsetHours * 60 * 60 * 1000));\nconst pad = n => String(n).padStart(2, '0');\nconst todayET = etNow.getUTCFullYear() + '-' + pad(etNow.getUTCMonth()+1) + '-' + pad(etNow.getUTCDate());\n\n// Filter: USD only, today only, any impact\nconst filtered = allEvents.filter(e => {\n  if (!e || !e.title) return false;\n  if (e.country !== 'USD') return false;\n  const impact = (e.impact || '').toLowerCase();\n  if (impact !== 'high' && impact !== 'medium' && impact !== 'low') return false;\n  const eventDate = (e.date || '').substring(0, 10);\n  return eventDate === todayET;\n}).sort((a, b) => (a.date || '').localeCompare(b.date || ''));\n\nconst dateLabel = etNow.toLocaleDateString('en-US', {\n  weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',\n  timeZone: 'UTC'\n});\nconst dateStr = todayET;\nconst tzLabel = etOffsetHours === -4 ? 'EDT' : 'EST';\n\nconst impactEmoji = i => ({ high: '\\uD83D\\uDD34', medium: '\\uD83D\\uDFE1', low: '\\u26AA' })[(i||'').toLowerCase()] || '\\u26AA';\n\nconst fmtTime = rawDate => {\n  try {\n    const t = (rawDate || '').split('T')[1];\n    if (!t) return 'All Day';\n    const parts = t.replace(/[+-]\\d{4}$/, '').split(':');\n    let h = parseInt(parts[0]);\n    const m = parts[1];\n    const ampm = h >= 12 ? 'PM' : 'AM';\n    if (h > 12) h -= 12;\n    if (h === 0) h = 12;\n    return h + ':' + m + ' ' + ampm + ' ' + tzLabel;\n  } catch(e) { return 'TBD'; }\n};\n\nconst fmtEvent = e => {\n  const emoji = impactEmoji(e.impact);\n  const time  = fmtTime(e.date);\n  const fore  = e.forecast ? '  Fcst: `' + e.forecast + '`' : '';\n  const prev  = e.previous ? '  \\u2502  Prev: `' + e.previous + '`' : '';\n  const act   = e.actual   ? '  \\u2502  **\\u2705 Act: `' + e.actual + '`**' : '';\n  const meta  = (fore || prev || act) ? '\\n> ' + (fore + prev + act).trim() : '';\n  return emoji + ' **' + e.title + '**  \\u00B7  ' + time + meta;\n};\n\nif (!filtered.length) {\n  const msg = [\n    '**\\uD83D\\uDCCA ECONOMIC CALENDAR \\u2014 TODAY**',\n    '**\\uD83D\\uDCC5 ' + dateLabel + '**',\n    '\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501',\n    '',\n    '_No major USD events scheduled today._',\n    '_Source: Forex Factory_'\n  ].join('\\n');\n  return [{ json: { message: msg, mode: 'daily', date: dateStr, eventCount: 0, eventsForSheets: [] } }];\n}\n\nconst high   = filtered.filter(e => (e.impact||'').toLowerCase() === 'high');\nconst medium = filtered.filter(e => (e.impact||'').toLowerCase() === 'medium');\nconst low    = filtered.filter(e => (e.impact||'').toLowerCase() === 'low');\n\nconst lines = [\n  '**\\uD83D\\uDCCA ECONOMIC CALENDAR \\u2014 TODAY**',\n  '**\\uD83D\\uDCC5 ' + dateLabel + '**',\n  '\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501\\u2501',\n  ''\n];\n\nif (high.length)   { lines.push('**\\uD83D\\uDD34 HIGH IMPACT**');   lines.push('\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500'); high.forEach(e   => lines.push(fmtEvent(e))); lines.push(''); }\nif (medium.length) { lines.push('**\\uD83D\\uDFE1 MEDIUM IMPACT**'); lines.push('\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500'); medium.forEach(e => lines.push(fmtEvent(e))); lines.push(''); }\nif (low.length)    { lines.push('**\\u26AA LOW IMPACT**');          lines.push('\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500'); low.forEach(e    => lines.push(fmtEvent(e))); lines.push(''); }\n\nlines.push('_Source: Forex Factory \\u2502 Times in ' + tzLabel + '_');\n\nconst eventsForSheets = filtered.map(e => ({\n  date: (e.date || '').substring(0, 10),\n  event: e.title || '',\n  time_et: fmtTime(e.date),\n  impact: e.impact || '',\n  currency: e.country || 'USD',\n  forecast: e.forecast || '',\n  previous: e.previous || '',\n  actual: e.actual || '',\n  mode: 'daily'\n}));\n\nreturn [{ json: { message: lines.join('\\n'), mode: 'daily', date: dateStr, eventCount: filtered.length, eventsForSheets } }];"
      },
      "name": "Format Daily Discord",
