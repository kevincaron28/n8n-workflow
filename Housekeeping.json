    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Transform EOD sheet data to database format\nconst row = $json;\nconst date = row.Date || row.date;\n\nreturn [{ json: {\n  date: date,\n  timestamp: row.Timestamp || new Date().toISOString(),\n  type: 'EOD',\n  spy_close: parseFloat(row.SPY_Close) || null,\n  spy_change: parseFloat(row.SPY_Change) || null,\n  qqq_change: parseFloat(row.QQQ_Change) || null,\n  iwm_change: parseFloat(row.IWM_Change) || null,\n  dia_change: parseFloat(row.DIA_Change) || null,\n  vix_close: parseFloat(row.VIX_Close) || null,\n  vix_change: parseFloat(row.VIX_Change) || null,\n  breadth_close: row.BreadthClose || null,\n  credit_close: row.CreditClose || null,\n  yield_10y: parseFloat(row.Yield10Y) || null,\n  yield_10y_change: parseFloat(row.Yield10Y_Change) || null,\n  rotation_bias: row.RotationBias || null,\n  rotation_score: parseInt(row.RotationScore) || null,\n  sector_ranking: row.SectorRanking || null,\n  top_3_sectors: row.Top3Sectors || null,\n  bot_3_sectors: row.Bot3Sectors || null,\n  xlk_change: parseFloat(row.XLK_Change) || null,\n  xly_change: parseFloat(row.XLY_Change) || null,\n  xlf_change: parseFloat(row.XLF_Change) || null,\n  xli_change: parseFloat(row.XLI_Change) || null,\n  xlb_change: parseFloat(row.XLB_Change) || null,\n  xle_change: parseFloat(row.XLE_Change) || null,\n  xlv_change: parseFloat(row.XLV_Change) || null,\n  xlu_change: parseFloat(row.XLU_Change) || null,\n  xlre_change: parseFloat(row.XLRE_Change) || null,\n  xlp_change: parseFloat(row.XLP_Change) || null,\n  xlc_change: parseFloat(row.XLC_Change) || null,\n  gold_change: parseFloat(row.Gold_Change) || null,\n  oil_change: parseFloat(row.Oil_Change) || null,\n  btc_change: parseFloat(row.BTC_Change) || null,\n  dxy_change: parseFloat(row.DXY_Change) || null,\n  unusual_movers: row.UnusualMovers || null,\n  pm_verdict: row.PM_Verdict || null,\n  pm_focus_sectors: row.PM_FocusSectors || null,\n  pm_rotation_bias: row.PM_RotationBias || null\n} }];"
      },
