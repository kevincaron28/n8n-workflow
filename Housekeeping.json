    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const row = $json;\nconst p = v => { const n = parseFloat(v); return isNaN(n) ? null : n; };\nconst i = v => { const n = parseInt(v); return isNaN(n) ? null : n; };\nreturn [{ json: {\n  date: row.Date,\n  timestamp: row.Timestamp || new Date().toISOString(),\n  type: row.Type || 'PRE-MARKET',\n  risk_verdict: row.RiskVerdict || null,\n  risk_score: i(row.RiskScore),\n  risk_factors: row.RiskFactors || null,\n  focus_sectors: row.FocusSectors || null,\n  top_3_sectors: row.Top3Sectors || null,\n  bot_3_sectors: row.Bot3Sectors || null,\n  rotation_bias: row.RotationBias || null,\n  rotation_score: i(row.RotationScore),\n  sector_ranking: row.SectorRanking || null,\n  vix: p(row.VIX),\n  regime: row.Regime || null,\n  leadership: row.Leadership || null,\n  breadth_signal: row.BreadthSignal || null,\n  credit_signal: row.CreditSignal || null,\n  breadth: row.Breadth || null,\n  liquidity: row.Liquidity || null,\n  es_price: p(row.ES_Price),\n  es_change: p(row.ES_Change),\n  nq_change: p(row.NQ_Change),\n  spy_price: p(row.SPY_Price),\n  spy_change: p(row.SPY_Change),\n  qqq_change: p(row.QQQ_Change),\n  iwm_change: p(row.IWM_Change),\n  gold_change: p(row.Gold_Change),\n  oil_change: p(row.Oil_Change),\n  btc_change: p(row.BTC_Change),\n  yield_10y: p(row.Yield10Y),\n  dxy_change: p(row.DXY_Change),\n  smh_change: p(row.SMH_Change),\n  iyt_change: p(row.IYT_Change),\n  xlk_change: p(row.XLK_Change),\n  xly_change: p(row.XLY_Change),\n  xlf_change: p(row.XLF_Change),\n  xli_change: p(row.XLI_Change),\n  xlb_change: p(row.XLB_Change),\n  xle_change: p(row.XLE_Change),\n  xlv_change: p(row.XLV_Change),\n  xlu_change: p(row.XLU_Change),\n  xlre_change: p(row.XLRE_Change),\n  xlp_change: p(row.XLP_Change),\n  xlc_change: p(row.XLC_Change)\n} }];"
      },
